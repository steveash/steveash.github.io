---
import Base from "../layouts/Base.astro";
import { getImage } from "astro:assets";
import avatarSource from "../assets/me-2018.jpg";

// Downscaled, metadata-stripped versions (the source carries phone GPS Exif).
const avatar = await getImage({
  src: avatarSource,
  width: 176,
  height: 176,
  format: "webp",
});
const ogImage = await getImage({
  src: avatarSource,
  width: 512,
  height: 512,
  format: "jpeg",
});

const links = [
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/ashsteve",
    icon: `<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>`,
  },
  {
    name: "GitHub",
    href: "https://github.com/steveash",
    icon: `<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>`,
  },
  {
    name: "Google Scholar",
    href: "https://scholar.google.com/citations?user=y16y5AwAAAAJ&hl=en",
    icon: `<path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>`,
  },
  {
    name: "Email",
    href: "mailto:stevemash@gmail.com",
    icon: `<path d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"/>`,
  },
];

const work = [
  {
    title: "Amazon Quick",
    meta: "Agentic AI platform for business users — unified conversational agents, BI, automation flows, and analysis/research agents.",
  },
  {
    title: "Amazon Q Scenarios",
    meta: "Interactive canvas for analyzing structured data in natural language, powered by planning, reasoning, and code agents. Led as technical owner from whiteboard to delivery.",
  },
  {
    title: "Generative BI in Amazon QuickSight Q",
    meta: "Authoring charts and calculations from natural language — the first major BI tool to put generative AI in customers' hands. Owned whiteboard to production.",
  },
  {
    title: "Amazon QuickSight Q",
    meta: "Natural-language Q&A over databases — shipped before ChatGPT.",
  },
  {
    title: "AWS Glue ML Transforms · FindMatches",
    meta: "Generic record-linkage-at-scale solution for AWS Glue.",
  },
  {
    title: "Identity & fraud at scale (ARGO, FIS)",
    meta: "Patient identity resolution across statewide hospital systems and HIEs; real-time and batch check-fraud detection at top US/Canada banks; check-image exchange among the top 25 US banks.",
  },
];

const title = "Steve Ash";
const description =
  "Steve Ash — Senior Principal Engineer at AWS and hands-on technical leader with 20+ years across academia and industry. PhD in computer science, 10+ patents, 10+ published papers in AI, distributed systems, and scale.";
---

<Base title={title} description={description} ogImage={ogImage.src}>
  <header class="header">
    <img class="avatar" src={avatar.src} alt="Steve Ash" width="88" height="88" />
    <div>
      <h1>Steve Ash</h1>
      <p class="tagline">Senior Principal Engineer, AWS · Agentic AI for Business · Seattle, WA</p>
    </div>
  </header>

  <section class="bio">
    <p>
      I'm a hands-on technical leader with 20+ years of experience solving
      problems at the intersection of academia and industry, delivering
      scalable, production software products. As a Senior Principal Engineer at
      AWS, I keep my hands on the keyboard while shaping technical strategy for
      orgs of 1,000+ people — and I care just as much about empowering the next
      generation of leaders as I do about the technology.
    </p>
    <p>
      I hold a PhD in computer science, with 10+ issued patents and 10+ papers
      published in academic conferences. I'm deeply curious, with extensive
      experience in AI, distributed systems, and scaling systems, people, and
      orgs. I love bootstrapping small, scrappy teams to deliver seemingly
      impossible projects, and I thrive under pressure and ambiguity.
    </p>
  </section>

  <h2>Find me</h2>
  <nav class="links">
    {
      links.map((l) => (
        <a href={l.href} rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true" set:html={l.icon} />
          {l.name}
        </a>
      ))
    }
  </nav>

  <h2>Selected work</h2>
  <ul class="highlights">
    {
      work.map((h) => (
        <li>
          <div class="h-title">{h.title}</div>
          <div class="h-meta">{h.meta}</div>
        </li>
      ))
    }
  </ul>

  <footer>
    <p>
      Older writing (2009–2016) lives in the <a href="/posts/">archive</a>, with
      a few old <a href="/talks/">talks</a>. ·
      &copy; {new Date().getFullYear()} Steve Ash
    </p>
  </footer>
</Base>
